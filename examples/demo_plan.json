{
  "name": "demo",
  "artifactsDir": "artifacts",
  "vars": {
    "BASE_URL": "https://www.bing.com",
    "KEYWORD": "瑞幸咖啡"
  },
  "browser": {
    "channel": "chromium",
    "headless": false,
    "slowMoMs": 0,
    "args": []
  },
  "context": {
    "viewport": { "width": 1280, "height": 720 }
  },
  "tests": [
    {
      "name": "bing_search",
      "steps": [
        { "action": "goto", "url": "${BASE_URL}", "waitUntil": "commit" },
        { "action": "wait_for_selector", "selector": "#sb_form_q", "state": "visible" },
        { "action": "type", "selector": "#sb_form_q", "text": "${KEYWORD}", "delayMs": 500 },
        { "action": "wait", "ms": 2000 },
        { "action": "press", "selector": "#sb_form_q", "key": "Enter" },
        { "action": "wait", "ms": 2000 },
        { "action": "screenshot", "path": "bing_search.png", "fullPage": true }
      ]
    }
  ]
}
